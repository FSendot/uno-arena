{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UnoArena production external platform dependency",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "component", "environment", "mode", "managedInCluster", "configuration", "preflight"],
  "properties": {
    "schemaVersion": {"const": 1},
    "component": {"type": "string", "minLength": 1},
    "environment": {"const": "production"},
    "mode": {"const": "external"},
    "managedInCluster": {"const": false},
    "configuration": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "name", "key"],
        "properties": {
          "kind": {"enum": ["Secret", "ConfigMap"]},
          "name": {"type": "string", "minLength": 1},
          "key": {"type": "string", "minLength": 1}
        }
      }
    },
    "preflight": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "expect"],
        "properties": {
          "type": {"enum": ["dns", "tcp", "tls", "http", "sql", "kafka-metadata", "s3", "oidc-discovery"]},
          "expect": {"type": "string", "minLength": 1}
        }
      }
    },
    "semantics": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
