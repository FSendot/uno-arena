#!/usr/bin/env bash
set -euo pipefail

source "$(dirname "$0")/platform-metadata.sh"
configure_release_component

: "${CI_PIPELINE_IID:?CI_PIPELINE_IID is required}"
: "${CI_COMMIT_SHORT_SHA:?CI_COMMIT_SHORT_SHA is required}"
: "${CI_COMMIT_SHA:?CI_COMMIT_SHA is required}"
: "${CI_API_V4_URL:?CI_API_V4_URL is required}"
: "${CI_PROJECT_ID:?CI_PROJECT_ID is required}"
: "${CI_JOB_TOKEN:?CI_JOB_TOKEN is required}"

chart_version="0.1.$CI_PIPELINE_IID"
mkdir -p artifacts
helm package "$CHART_PATH" --destination artifacts --version "$chart_version" --app-version "$CI_COMMIT_SHORT_SHA"
package="artifacts/$CHART_NAME-$chart_version.tgz"
curl --fail-with-body --request POST \
  --user "gitlab-ci-token:$CI_JOB_TOKEN" \
  --form "chart=@$package" \
  "$CI_API_V4_URL/projects/$CI_PROJECT_ID/packages/helm/api/stable/charts"

package_sha="$(ruby -rdigest -e 'puts Digest::SHA256.file(ARGV.fetch(0)).hexdigest' "$package")"
repository="$CI_API_V4_URL/projects/$CI_PROJECT_ID/packages/helm/stable"
COMPONENT="$COMPONENT" REPOSITORY="$repository" CHART_NAME="$CHART_NAME" CHART_VERSION="$chart_version" PACKAGE_SHA="$package_sha" SOURCE_SHA="$CI_COMMIT_SHA" \
  ruby -rjson -e 'puts JSON.pretty_generate({schemaVersion: 1, component: ENV.fetch("COMPONENT"), sourceSha: ENV.fetch("SOURCE_SHA"), chart: {repository: ENV.fetch("REPOSITORY"), name: ENV.fetch("CHART_NAME"), version: ENV.fetch("CHART_VERSION"), packageSha256: ENV.fetch("PACKAGE_SHA")}})' \
  > "artifacts/$COMPONENT-chart.json"
