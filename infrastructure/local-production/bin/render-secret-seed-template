#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "yaml"

schema_path = File.expand_path("../charts/platform-secrets/seed.schema.json", __dir__)
required = JSON.parse(File.read(schema_path)).fetch("required")
document = {
  "apiVersion" => "v1",
  "kind" => "Secret",
  "metadata" => {"name" => "uno-arena-local-credentials", "namespace" => "secret-seed"},
  "type" => "Opaque",
  "stringData" => required.to_h { |property| [property, "REPLACE_WITH_SECRET"] }
}

puts YAML.dump(document)
