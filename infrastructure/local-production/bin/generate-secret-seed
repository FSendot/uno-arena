#!/usr/bin/env ruby
# frozen_string_literal: true

require "base64"
require "json"
require "optparse"
require "securerandom"
require "yaml"

begin
options = {}
OptionParser.new do |parser|
  parser.banner = "usage: #{$PROGRAM_NAME} --registry-config PATH --output PATH"
  parser.on("--registry-config PATH") { |value| options[:registry_config] = value }
  parser.on("--output PATH") { |value| options[:output] = value }
end.parse!

registry_path = options.fetch(:registry_config) { abort "--registry-config is required" }
output_path = options.fetch(:output) { abort "--output is required" }
abort "registry config must be a regular file" unless File.file?(registry_path) && !File.symlink?(registry_path)
abort "output parent directory does not exist" unless File.directory?(File.dirname(File.expand_path(output_path)))
abort "refusing to overwrite seed output" if File.exist?(output_path) || File.symlink?(output_path)

registry_raw = File.read(registry_path)
registry = JSON.parse(registry_raw)
abort "registry config must be a JSON object" unless registry.is_a?(Hash)
abort "registry config must not delegate to a credential store" if
  registry.key?("credsStore") || registry.key?("credHelpers")
auths = registry["auths"]
abort "registry config must contain only registry.gitlab.com auth" unless
  auths.is_a?(Hash) && auths.keys == ["registry.gitlab.com"]
registry_auth = auths.fetch("registry.gitlab.com")
abort "registry.gitlab.com auth must be a JSON object" unless registry_auth.is_a?(Hash)
auth = registry_auth["auth"]
abort "registry config is missing embedded registry.gitlab.com auth" unless auth.is_a?(String) && !auth.empty?
decoded_auth = Base64.strict_decode64(auth)
registry_username, registry_password = decoded_auth.split(":", 2)
abort "registry config contains invalid embedded auth" if
  registry_username.to_s.empty? || registry_password.to_s.empty?
registry_raw = JSON.generate({"auths" => {"registry.gitlab.com" => {"auth" => auth}}})
registry_password = nil
decoded_auth = nil

schema_path = File.expand_path("../charts/platform-secrets/seed.schema.json", __dir__)
required = JSON.parse(File.read(schema_path)).fetch("required")

secret = -> { SecureRandom.urlsafe_base64(32, false) }
password = -> { SecureRandom.urlsafe_base64(36, false) }
values = {
  "alertmanager-webhook-url" => "http://alert-webhook-sink.observability.svc.cluster.local:8080/alerts",
  "gitlab-registry-dockerconfigjson" => registry_raw,
  "game-integrity-envelope-dev-keys" => "1:#{SecureRandom.hex(32)}",
  "minio-access-key-id" => "unoarena#{SecureRandom.hex(6)}",
  "minio-secret-access-key" => SecureRandom.hex(24),
  "grafana-admin-user" => "admin",
  "keycloak-admin-user" => "admin"
}

usernames = {
  "identity-admin-user" => "identity_admin",
  "identity-bootstrap-user" => "identity_bootstrap",
  "identity-runtime-user" => "identity_runtime",
  "identity-cdc-user" => "identity_cdc",
  "room-admin-user" => "room_admin",
  "room-bootstrap-user" => "room_bootstrap",
  "room-runtime-user" => "room_runtime",
  "room-cdc-kafka-user" => "room_cdc_kafka",
  "room-cdc-realtime-user" => "room_cdc_realtime",
  "tournament-admin-user" => "tournament_admin",
  "tournament-bootstrap-user" => "tournament_bootstrap",
  "tournament-runtime-user" => "tournament_runtime",
  "tournament-cdc-user" => "tournament_cdc",
  "ranking-admin-user" => "ranking_admin",
  "ranking-bootstrap-user" => "ranking_bootstrap",
  "ranking-runtime-user" => "ranking_runtime",
  "ranking-cdc-user" => "ranking_cdc",
  "clickhouse-admin-user" => "clickhouse_admin",
  "analytics-bootstrap-user" => "analytics_bootstrap",
  "analytics-runtime-user" => "analytics_runtime"
}
values.merge!(usernames)

(usernames.keys + %w[grafana-admin-user keycloak-admin-user]).each do |user_key|
  values[user_key.sub(/-user\z/, "-password")] = password.call
end

random_secret_keys = %w[
  analytics-ops-credential
  analytics-ranking-credential
  analytics-room-credential
  analytics-tournament-credential
  game-integrity-audit-credential
  game-integrity-internal-credential
  identity-internal-credential
  ranking-analytics-backfill-cursor-secret
  ranking-internal-credential
  ranking-leaderboard-cursor-secret
  room-analytics-backfill-cursor-secret
  room-identity-credential
  room-public-list-cursor-secret
  room-runtime-router-credential
  room-service-credential
  room-spectator-recovery-service-credential
  room-timer-service-credential
  room-to-gateway-credential
  spectator-view-internal-credential
  tournament-analytics-backfill-cursor-secret
  tournament-bracket-cursor-secret
  tournament-internal-credential
]
random_secret_keys.each { |key| values[key] = secret.call }

hmac_key = SecureRandom.hex(32)
values["internal-principal-hmac-key-current"] = hmac_key
values["internal-principal-hmac-key-previous"] = hmac_key

values["identity-database-url"] =
  "postgres://#{values.fetch('identity-runtime-user')}:#{values.fetch('identity-runtime-password')}@" \
  "postgres-identity.uno-arena.svc.cluster.local:5432/identity?sslmode=disable"
values["room-database-url"] =
  "postgres://#{values.fetch('room-runtime-user')}:#{values.fetch('room-runtime-password')}@" \
  "postgres-room-gameplay.uno-arena.svc.cluster.local:5432/room_gameplay?sslmode=disable"
values["room-pgbouncer-database-url"] =
  "postgres://#{values.fetch('room-runtime-user')}:#{values.fetch('room-runtime-password')}@" \
  "room-gameplay-pgbouncer.uno-arena.svc.cluster.local:6432/room_gameplay?sslmode=disable"
values["room-pgbouncer-userlist"] =
  %("#{values.fetch('room-runtime-user')}" "#{values.fetch('room-runtime-password')}")
values["tournament-database-url"] =
  "postgres://#{values.fetch('tournament-runtime-user')}:#{values.fetch('tournament-runtime-password')}@" \
  "postgres-tournament.uno-arena.svc.cluster.local:5432/tournament?sslmode=disable"
values["ranking-database-url"] =
  "postgres://#{values.fetch('ranking-runtime-user')}:#{values.fetch('ranking-runtime-password')}@" \
  "postgres-ranking.uno-arena.svc.cluster.local:5432/ranking?sslmode=disable"

missing = required - values.keys
extra = values.keys - required
abort "generated seed keys do not match schema; missing=#{missing.sort.join(',')} extra=#{extra.sort.join(',')}" unless
  missing.empty? && extra.empty?

document = {
  "apiVersion" => "v1",
  "kind" => "Secret",
  "metadata" => {"name" => "uno-arena-local-credentials", "namespace" => "secret-seed"},
  "type" => "Opaque",
  "stringData" => required.to_h { |key| [key, values.fetch(key)] }
}

flags = File::WRONLY | File::CREAT | File::EXCL
File.open(output_path, flags, 0o600) { |file| file.write(YAML.dump(document)) }
File.chmod(0o600, output_path)
puts "ok local-production-secret-seed output=#{output_path} properties=#{required.length}"
rescue JSON::ParserError, ArgumentError, KeyError, OptionParser::ParseError => e
  warn "secret seed generation failed: #{e.message}"
  exit 1
end
