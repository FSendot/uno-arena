# Copy to .env for local overrides. Do not commit real secrets.
# Image tags are pinned defaults — never rely on :latest.
# Local-only credential defaults below are for compose/CLI only; Helm uses existingSecret/secretKeyRef.

# --- Infra images ---
# Postgres 18 mounts at /var/lib/postgresql with named volumes *_v18
# (pg_identity_data_v18, pg_room_data_v18, pg_tournament_data_v18, pg_ranking_data_v18).
# Prior PG16 volumes (pg_*_data without _v18) are preserved and not reused. Reset =
# start with empty *_v18 volumes; migrate = dump/restore into *_v18. Do not delete
# volumes from compose.
POSTGRES_IMAGE=postgres:18.4-alpine3.24
KAFKA_IMAGE=apache/kafka:4.3.1
# Native ARM64 local image, pinned by digest. It is experimental and local-only.
KURRENTDB_IMAGE=kurrentplatform/kurrentdb:26.0.3-experimental-arm64-10.0-noble@sha256:8498556a8ba7a74f8d4ea31a149b1e5216e167d6884b630a68b3e1eb9e6e870e
# AMD64 durable/production candidate: docker.kurrent.io/kurrent-lts/kurrentdb:26.0.3@sha256:b4d0665a78269cd7184971c4d1fad38265277901f3d3730d89dcfba8f3d37fe9
REDIS_IMAGE=redis:8.8.0-alpine
CLICKHOUSE_IMAGE=clickhouse/clickhouse-server:26.6.1.1193
# kind foundation pins (local only; see infrastructure/kind/)
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.7.0
BOOTSTRAP_IMAGE=uno-arena/bootstrap:local

# --- Service images (local tags; build via compose) ---
GATEWAY_IMAGE=uno-arena/gateway:local
IDENTITY_IMAGE=uno-arena/identity:local
ROOM_GAMEPLAY_IMAGE=uno-arena/room-gameplay:local
GAME_INTEGRITY_IMAGE=uno-arena/game-integrity:local
TOURNAMENT_IMAGE=uno-arena/tournament-orchestration:local
RANKING_IMAGE=uno-arena/ranking:local
SPECTATOR_VIEW_IMAGE=uno-arena/spectator-view:local
ANALYTICS_IMAGE=uno-arena/analytics:local

# --- Infra credentials (local-only defaults) ---
POSTGRES_USER=uno
POSTGRES_PASSWORD=uno
CLICKHOUSE_USER=uno
CLICKHOUSE_PASSWORD=uno
# Durable Analytics (local/kind): set CLICKHOUSE_URL + scoped runtime user/password.
# Capability overlay clears CLICKHOUSE_URL and sets ANALYTICS_CAPABILITY_MODE=true.
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KURRENTDB_URL=kurrentdb://kurrentdb:2113?tls=false

# --- Host publish (BFF only) ---
BFF_HOST_PORT=8080

# --- Scoped internal credentials (local-only defaults; distinct names) ---
# Gateway outbound to backends is context-scoped. Prefer explicit GATEWAY_*_SERVICE_CREDENTIAL
# envs; GATEWAY_SERVICE_CREDENTIAL is only a backward-compat fallback when an explicit
# outbound env is unset. Inbound GATEWAY_*_CREDENTIAL producer envs are separate and must
# not be reused for outbound HTTP.
GATEWAY_SERVICE_CREDENTIAL=local-gw-backend
GATEWAY_IDENTITY_SERVICE_CREDENTIAL=local-gw-backend
GATEWAY_ROOM_SERVICE_CREDENTIAL=local-gw-backend
GATEWAY_TOURNAMENT_SERVICE_CREDENTIAL=local-room-to-tournament
GATEWAY_SPECTATOR_SERVICE_CREDENTIAL=local-room-to-spectator
GATEWAY_IDENTITY_CREDENTIAL=local-gw-backend
GATEWAY_ROOM_CREDENTIAL=local-room-to-gw
GATEWAY_SPECTATOR_CREDENTIAL=local-spectator-to-gw

IDENTITY_INTERNAL_CREDENTIAL=local-gw-backend

ROOM_SERVICE_CREDENTIAL=local-gw-backend
ROOM_TIMER_SERVICE_CREDENTIAL=local-room-timer
ROOM_TO_GATEWAY_CREDENTIAL=local-room-to-gw
ROOM_IDENTITY_CREDENTIAL=local-gw-backend
ROOM_GI_CREDENTIAL=local-gi-room

GAME_INTEGRITY_INTERNAL_CREDENTIAL=local-gi-room
GAME_INTEGRITY_AUDIT_CREDENTIAL=local-gi-operator
# Local-only envelope encryption (ADR-0024). Exactly 32 bytes as 64 hex chars; never use in staging/production.
GAME_INTEGRITY_ENVELOPE_PROVIDER=dev
GAME_INTEGRITY_ENVELOPE_KEY_VERSION=1
# Versioned local-only keyring: <version>:<64hex>[,...]. Current wrap version is KEY_VERSION.
GAME_INTEGRITY_ENVELOPE_DEV_KEYS=1:0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
DEPLOYMENT_ENV=local

# --- Identity durable + OIDC (local/kind; never enable direct grant in staging/production) ---
# DATABASE_URL enables durable pgx mode. IDENTITY_CAPABILITY_MODE=true keeps memory (non-prod only).
# OIDC_ISSUER_URL must match the IdP iss claim (in-cluster Keycloak service DNS for kind).
# OIDC_TOKEN_ENDPOINT may differ when the token endpoint is reached via another host/port.
# OIDC_ISSUER_URL=http://keycloak.uno-arena.svc.cluster.local:8080/realms/unoarena
# OIDC_TOKEN_ENDPOINT=http://keycloak.uno-arena.svc.cluster.local:8080/realms/unoarena/protocol/openid-connect/token
# OIDC_AUDIENCE=unoarena-cli
# OIDC_CLIENT_ID=unoarena-cli
# OIDC_ALLOW_HTTP=true
# IDENTITY_ALLOW_PASSWORD_LOGIN=true
# IDENTITY_OIDC_DIRECT_GRANT=true
# IDENTITY_ALLOW_TEST_PROVISIONING=true
# IDENTITY_SCHEMA_CHECKSUM=  # optional override; defaults to bootstrap fingerprint

# --- Room Gameplay durable (local/kind) ---
# DATABASE_URL + REDIS_URL enable durable Postgres session/UoW + Redis timer index.
# ROOM_CAPABILITY_MODE=true keeps memory session (non-prod only); never silent fallback.
# Debezium Kafka + Redis sink delivery for dual outboxes remain PENDING (shared CDC).
# ROOM_SCHEMA_CHECKSUM=  # optional override; defaults to bootstrap fingerprint
# WORKER_ROLE=room-timer  # timer worker binary role (same image as API)

TOURNAMENT_INTERNAL_CREDENTIAL=local-room-to-tournament
SPECTATOR_VIEW_INTERNAL_CREDENTIAL=local-room-to-spectator
RANKING_INTERNAL_CREDENTIAL=local-ranking-internal

ANALYTICS_ROOM_CREDENTIAL=local-analytics-room
ANALYTICS_RANKING_CREDENTIAL=local-analytics-ranking
ANALYTICS_TOURNAMENT_CREDENTIAL=local-analytics-tournament
ANALYTICS_OPS_CREDENTIAL=local-analytics-ops

# --- Capability overlay (docker-compose.capability.yml only; do not set in base) ---
# GATEWAY_CAPABILITY_MODE=true   # real HTTP upstreams + in-memory edge/principal limiters
# ROOM_CAPABILITY_MODE=true      # memory session repo; real Identity/GI/publisher HTTP paths
# IDENTITY_CAPABILITY_MODE=true  # Identity memory path; durable uses DATABASE_URL instead
# GAME_INTEGRITY_ALLOW_MEMORY=true
# Do not set GATEWAY_ALLOW_FAKES / ROOM_ALLOW_FAKES in the capability overlay — those
# fake backends and prevent the CLI from traversing real service HTTP paths.
