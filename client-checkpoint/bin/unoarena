#!/usr/bin/env bash
# UnoArena Client Checkpoint CLI — sole client/test interface for this implementation.
# Speaks only to the Realtime Gateway / BFF via UNOARENA_API_URL. No direct service calls.
set -euo pipefail

SEED_MAX_COUNT=10000
SEED_DEFAULT_PREFIX="seed"

usage() {
  cat >&2 <<'USAGE'
Usage:
  unoarena health
  unoarena register --user <username> --pass <password>
  unoarena login --user <username> --pass <password>
  unoarena logout
  unoarena whoami [--token <bearer-token>]
  unoarena seed --count <N> [--prefix <p>]
  unoarena room create [--max <N>] [--token <bearer-token>] [--command-id <id>]
                       [--payload <json>]
  unoarena room list [--status <waiting|locked|in_progress>] [--limit <n>] [--cursor <c>]
  unoarena room join <roomId> [--token <bearer-token>] [--command-id <id>]
  unoarena room leave [<roomId>] [--token <bearer-token>] [--command-id <id>]
  unoarena command --token <bearer-token> --type <CommandType>
                   [--room-id <roomId>] [--command-id <id>]
                   --expected-sequence <n>   # required for existing room mutations
                   [--payload <json>] [--schema-version <n>]
  unoarena tournament create --token <bearer-token> [--command-id <id>] [--payload <json>]
  unoarena tournament register <tournamentId> [--token <bearer-token>] [--command-id <id>]
  unoarena tournament register --token <bearer-token> [--command-id <id>] --payload <json>
  unoarena tournament close-registration --token <bearer-token>
                   [--command-id <id>] [--payload <json>]
  unoarena tournament status <tournamentId> [--token <bearer-token>]
  unoarena stream player --token <bearer-token> --room-id <roomId> [--last-event-id <id>]
  unoarena stream spectator --room-id <roomId> [--token <bearer-token>] [--last-event-id <id>]
  unoarena spectate <roomId> [--token <bearer-token>] [--last-event-id <id>]
  unoarena stream control --token <bearer-token> [--last-event-id <id>]
  unoarena leaderboard
  unoarena analytics
  unoarena countdown --expires-at <RFC3339> --opening-sequence <n>
                   [--now <RFC3339>] [--json]
  unoarena play --casual [--user <u> --pass <p> | --token <bearer-token>] [--json]
  unoarena bot [--casual | --room <roomId> | --tournament <tournamentId>]
                   [--user <u> --pass <p> | --token <bearer-token>] [--seed <rng>]

Environment:
  UNOARENA_API_URL       Gateway/BFF base URL (required except for countdown/logout)
  UNOARENA_TOKEN         Optional default bearer token when --token is omitted
  UNOARENA_SESSION_FILE  Override session file path (default: XDG state / home)

Notes:
  - All HTTP calls target UNOARENA_API_URL only (OpenAPI BFF paths).
  - Token resolution for one-shot utilities: --token, then UNOARENA_TOKEN, then session file.
  - Interactive play is line-oriented; --json emits JSON Lines for events/actions.
  - Bot mode always emits JSON Lines and a final summary.
  - schemaVersion must equal 1.
  - The public command catalog is closed (15 OpenAPI types). Unknown --type
    values are rejected locally before send.
  - expectedSequenceNumber is required for mutations of an existing room aggregate
    (JoinRoom, PlayCard, …). It must be absent for CreateRoom and the three
    tournament types; passing --expected-sequence for those is rejected locally.
  - seed passwords are deterministic: password = "<username>-pass"
    (usernames = "<prefix><NNNN>" with 1-based zero-padded index).
  - Countdown is advisory; server expiresAt + openingSequence remain authoritative.
    SSE advisory accepts canonical openingSequence and legacy openingRoomSequence.
  - Graphical UI is deferred; this CLI is the sole current client interface.
USAGE
  exit 2
}

fail() {
  echo "FAIL: $*" >&2
  exit 1
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    fail "required command '$1' is not available"
  fi
}

# Strict non-negative integer (digits only). Rejects signs, decimals, whitespace.
require_uint() {
  local label="$1" value="$2"
  case "$value" in
    ''|*[!0-9]*)
      fail "${label} must be a non-negative integer (got: ${value})"
      ;;
  esac
}

require_positive_uint() {
  local label="$1" value="$2"
  require_uint "$label" "$value"
  if [ "$value" -lt 1 ]; then
    fail "${label} must be >= 1 (got: ${value})"
  fi
}

# schemaVersion must equal 1 (current BFF contract).
require_schema_version() {
  local value="$1"
  require_uint "schemaVersion" "$value"
  if [ "$value" -ne 1 ]; then
    fail "schemaVersion must be 1 (got: ${value})"
  fi
}

urlencode() {
  local value="$1"
  local encoded=""
  local i char

  LC_ALL=C
  for ((i = 0; i < ${#value}; i++)); do
    char="${value:i:1}"
    case "$char" in
      [a-zA-Z0-9.~_-]) encoded+="$char" ;;
      *) printf -v encoded '%s%%%02X' "$encoded" "'$char" ;;
    esac
  done

  printf '%s' "$encoded"
}

generate_id() {
  local prefix="${1:-id}"
  if command -v uuidgen >/dev/null 2>&1; then
    printf '%s' "$(uuidgen | tr '[:upper:]' '[:lower:]')"
    return
  fi
  if [ -r /proc/sys/kernel/random/uuid ]; then
    tr -d '\n' </proc/sys/kernel/random/uuid
    return
  fi
  printf '%s-%s-%s' "$prefix" "$$" "$(date -u +%Y%m%d%H%M%S)"
}

generate_command_id() {
  generate_id "cmd"
}

generate_correlation_id() {
  generate_id "corr"
}

# Build JSON object via python stdlib (safe encoding).
# Args are triplets: KIND KEY VALUE
#   string — always a JSON string (untrusted scalars: username, password, ids, types)
#   number — already-validated non-negative integer
#   bool   — already-validated true/false
#   json   — already-validated JSON value (e.g. payload object)
# No in-band value sentinel: a string beginning with "raw:" stays a string.
json_object() {
  require_command python3
  python3 - "$@" <<'PY'
import json, sys

args = sys.argv[1:]
if len(args) % 3 != 0:
    print("FAIL: json_object requires kind/key/value triplets", file=sys.stderr)
    sys.exit(1)

out = {}
i = 0
while i < len(args):
    kind = args[i]
    key = args[i + 1]
    val = args[i + 2]
    i += 3
    if kind == "string":
        out[key] = val
    elif kind == "number":
        if not val.isdigit():
            print(f"FAIL: number field {key} must be a non-negative integer (got: {val})", file=sys.stderr)
            sys.exit(1)
        out[key] = int(val)
    elif kind == "bool":
        if val == "true":
            out[key] = True
        elif val == "false":
            out[key] = False
        else:
            print(f"FAIL: bool field {key} must be true or false (got: {val})", file=sys.stderr)
            sys.exit(1)
    elif kind == "json":
        try:
            out[key] = json.loads(val)
        except json.JSONDecodeError as exc:
            print(f"FAIL: invalid JSON for {key}: {exc}", file=sys.stderr)
            sys.exit(1)
    else:
        print(f"FAIL: unknown json_object kind '{kind}' (use string|number|bool|json)", file=sys.stderr)
        sys.exit(1)

print(json.dumps(out, separators=(",", ":")))
PY
}

# Validate payload is a JSON object; reprint canonical form.
canonicalize_payload_object() {
  local payload="$1"
  require_command python3
  python3 - "$payload" <<'PY'
import json, sys

raw = sys.argv[1]
try:
    obj = json.loads(raw)
except json.JSONDecodeError as exc:
    print(f"FAIL: payload must be valid JSON: {exc}", file=sys.stderr)
    sys.exit(1)
if not isinstance(obj, dict):
    print("FAIL: payload must be a JSON object", file=sys.stderr)
    sys.exit(1)
print(json.dumps(obj, separators=(",", ":")))
PY
}

json_get() {
  local json="$1" field="$2"
  require_command python3
  printf '%s' "$json" | python3 -c '
import json, sys
field = sys.argv[1]
try:
    data = json.load(sys.stdin)
except json.JSONDecodeError:
    sys.exit(1)
v = data.get(field, "")
if v is None:
    print("")
elif isinstance(v, (dict, list)):
    print(json.dumps(v, separators=(",", ":")))
else:
    print(v)
' "$field"
}

# Portable RFC3339 -> epoch seconds (UTC). Uses python3 stdlib only.
rfc3339_to_epoch() {
  local stamp="$1"
  python3 - "$stamp" <<'PY'
import sys
from datetime import datetime, timezone

raw = sys.argv[1]
if raw.endswith("Z"):
    raw = raw[:-1] + "+00:00"
dt = datetime.fromisoformat(raw)
if dt.tzinfo is None:
    dt = dt.replace(tzinfo=timezone.utc)
print(int(dt.timestamp()))
PY
}

# Closed public catalog (15 OpenAPI variants). Sequence rules:
# - prohibited: CreateRoom + tournament types
# - required: existing-room mutations
# - unknown: reject locally (outside catalog), including room-scoped paths
command_sequence_policy() {
  # prints: required | prohibited | unknown
  local cmd_type="$1"
  case "$cmd_type" in
    CreateRoom|CreateTournament|RegisterPlayer|CloseRegistration)
      echo "prohibited"
      ;;
    JoinRoom|LeaveRoom|LockRoom|StartMatch|CancelRoom|PlayCard|DrawCard|ChooseColor|CallUno|ReportMissingUno|ReconnectToRoom)
      echo "required"
      ;;
    *)
      echo "unknown"
      ;;
  esac
}

# --- session file helpers ---------------------------------------------------

session_path() {
  if [ -n "${UNOARENA_SESSION_FILE:-}" ]; then
    printf '%s' "$UNOARENA_SESSION_FILE"
    return
  fi
  local state_home="${XDG_STATE_HOME:-}"
  if [ -z "$state_home" ]; then
    state_home="${HOME}/.local/state"
  fi
  printf '%s' "${state_home}/unoarena/session.json"
}

# Fail closed when the session file exists but is corrupt or world/group-readable.
# Prints nothing and returns 1 when the file is absent (caller decides).
# On success prints the JSON object on stdout.
session_read_json() {
  local path
  path="$(session_path)"
  if [ ! -e "$path" ]; then
    return 1
  fi
  require_command python3
  python3 - "$path" <<'PY'
import json, os, stat, sys

path = sys.argv[1]
try:
    st = os.stat(path)
except OSError as exc:
    print(f"FAIL: cannot read session file: {exc}", file=sys.stderr)
    sys.exit(1)
mode = st.st_mode
if mode & (stat.S_IRWXG | stat.S_IRWXO):
    print("FAIL: session file permissions are unsafe (must be owner-only, mode 0600)", file=sys.stderr)
    sys.exit(1)
try:
    with open(path, "r", encoding="utf-8") as f:
        data = json.load(f)
except (OSError, json.JSONDecodeError) as exc:
    print(f"FAIL: corrupt session file: {exc}", file=sys.stderr)
    sys.exit(1)
if not isinstance(data, dict):
    print("FAIL: corrupt session file: root must be a JSON object", file=sys.stderr)
    sys.exit(1)
for key in ("token", "playerId", "sessionId", "username"):
    val = data.get(key)
    if not isinstance(val, str) or not val:
        print(f"FAIL: corrupt session file: missing or invalid '{key}'", file=sys.stderr)
        sys.exit(1)
room = data.get("roomId")
if room is not None and (not isinstance(room, str) or not room):
    print("FAIL: corrupt session file: invalid 'roomId'", file=sys.stderr)
    sys.exit(1)
print(json.dumps(data, separators=(",", ":")))
PY
}

session_write() {
  local token="$1" player_id="$2" session_id="$3" username="$4" room_id="${5:-}"
  local path dir
  path="$(session_path)"
  dir="$(dirname "$path")"
  require_command python3
  mkdir -p "$dir"
  python3 - "$path" "$token" "$player_id" "$session_id" "$username" "$room_id" <<'PY'
import json, os, sys

path, token, player_id, session_id, username, room_id = sys.argv[1:7]
payload = {
    "token": token,
    "playerId": player_id,
    "sessionId": session_id,
    "username": username,
}
if room_id:
    payload["roomId"] = room_id
dirpath = os.path.dirname(path) or "."
fd, tmp = -1, None
try:
    import tempfile
    fd, tmp = tempfile.mkstemp(prefix=".unoarena-session-", dir=dirpath, text=True)
    with os.fdopen(fd, "w", encoding="utf-8") as f:
        fd = -1
        json.dump(payload, f, separators=(",", ":"))
        f.write("\n")
        f.flush()
        os.fsync(f.fileno())
    os.chmod(tmp, 0o600)
    os.replace(tmp, path)
    tmp = None
except Exception as exc:
    if fd >= 0:
        try:
            os.close(fd)
        except OSError:
            pass
    if tmp:
        try:
            os.unlink(tmp)
        except OSError:
            pass
    print(f"FAIL: unable to write session file: {exc}", file=sys.stderr)
    sys.exit(1)
PY
}

session_update_room() {
  # Sets or clears roomId on an existing session file. No-op if absent.
  local room_id="${1:-}"
  local path json
  path="$(session_path)"
  if [ ! -e "$path" ]; then
    return 0
  fi
  json="$(session_read_json)" || return 1
  local token player_id session_id username
  token="$(json_get "$json" token)"
  player_id="$(json_get "$json" playerId)"
  session_id="$(json_get "$json" sessionId)"
  username="$(json_get "$json" username)"
  session_write "$token" "$player_id" "$session_id" "$username" "$room_id"
}

session_clear_room() {
  session_update_room ""
}

session_remove() {
  local path
  path="$(session_path)"
  rm -f "$path"
}

session_token_or_empty() {
  local json
  if ! json="$(session_read_json 2>/dev/null)"; then
    # Distinguish absent vs fail-closed: re-run without swallowing failures when file exists.
    if [ -e "$(session_path)" ]; then
      session_read_json >/dev/null
      return 1
    fi
    return 1
  fi
  json_get "$json" token
}

session_room_or_empty() {
  local json
  json="$(session_read_json)" || return 1
  json_get "$json" roomId
}

session_player_id() {
  local json
  json="$(session_read_json)" || return 1
  json_get "$json" playerId
}

# Resolve TOKEN after flags: --token > UNOARENA_TOKEN > session file.
# TOKEN_FROM_FLAG=1 means --token was supplied (even if empty → usage later).
resolve_token() {
  if [ "${TOKEN_FROM_FLAG:-0}" -eq 1 ]; then
    return 0
  fi
  if [ -n "${UNOARENA_TOKEN:-}" ]; then
    TOKEN="$UNOARENA_TOKEN"
    return 0
  fi
  local path
  path="$(session_path)"
  if [ -e "$path" ]; then
    local json
    json="$(session_read_json)" || exit 1
    TOKEN="$(json_get "$json" token)"
    return 0
  fi
  TOKEN=""
}

http_exchange() {
  # http_exchange METHOD PATH [curl args...]
  # Sets HTTP_CODE and HTTP_BODY. Does not exit on HTTP status.
  local method="$1"
  local path="$2"
  shift 2
  local url="${BASE_URL}${path}"
  local tmp_body tmp_code curl_rc
  tmp_body="$(mktemp)"
  tmp_code="$(mktemp)"

  local corr="${CORRELATION_ID:-}"
  if [ -z "$corr" ]; then
    corr="$(generate_correlation_id)"
  fi

  set +e
  curl --silent --show-error \
    --request "$method" \
    --output "$tmp_body" \
    --write-out '%{http_code}' \
    --header "X-Correlation-Id: ${corr}" \
    "$@" \
    "$url" >"$tmp_code"
  curl_rc=$?
  set -e

  HTTP_CODE="$(tr -d '\n' <"$tmp_code")"
  HTTP_BODY="$(cat "$tmp_body")"
  rm -f "$tmp_body" "$tmp_code"

  if [ "$curl_rc" -ne 0 ]; then
    fail "HTTP request failed (curl exit ${curl_rc}) ${method} ${url}"
  fi
}

http_json() {
  # http_json METHOD PATH [curl args...]
  # Prints response body on stdout. Exits 1 on transport/HTTP error with clear stderr.
  http_exchange "$@"
  if [ "$HTTP_CODE" -lt 200 ] || [ "$HTTP_CODE" -ge 300 ]; then
    echo "FAIL: $1 $2 returned HTTP ${HTTP_CODE}" >&2
    if [ -n "$HTTP_BODY" ]; then
      echo "$HTTP_BODY" >&2
    fi
    exit 1
  fi

  printf '%s' "$HTTP_BODY"
  if [ -n "$HTTP_BODY" ] && [ "${HTTP_BODY%"${HTTP_BODY##?}"}" != $'\n' ]; then
    printf '\n'
  fi
}

submit_command_envelope() {
  local token="$1"
  local cmd_type="$2"
  local command_id="$3"
  local schema_version="$4"
  local payload_json="$5"
  local room_id="${6:-}"
  local expected_sequence="${7:-}"

  [ -n "$token" ] || usage
  [ -n "$cmd_type" ] || usage
  [ -n "$command_id" ] || command_id="$(generate_command_id)"
  [ -n "$schema_version" ] || schema_version="1"
  [ -n "$payload_json" ] || payload_json="{}"

  require_schema_version "$schema_version"
  payload_json="$(canonicalize_payload_object "$payload_json")"

  local seq_policy
  seq_policy="$(command_sequence_policy "$cmd_type")"
  case "$seq_policy" in
    unknown)
      fail "command type '${cmd_type}' is outside the public catalog (15 OpenAPI variants)"
      ;;
    required)
      if [ -z "$expected_sequence" ]; then
        fail "expectedSequenceNumber is required for room mutation '${cmd_type}'"
      fi
      require_uint "expectedSequenceNumber" "$expected_sequence"
      ;;
    prohibited)
      if [ -n "$expected_sequence" ]; then
        fail "expectedSequenceNumber is not allowed for '${cmd_type}'"
      fi
      ;;
  esac

  local body
  if [ -n "$expected_sequence" ]; then
    body="$(json_object \
      string commandId "$command_id" \
      string type "$cmd_type" \
      number schemaVersion "$schema_version" \
      number expectedSequenceNumber "$expected_sequence" \
      json payload "$payload_json")"
  else
    body="$(json_object \
      string commandId "$command_id" \
      string type "$cmd_type" \
      number schemaVersion "$schema_version" \
      json payload "$payload_json")"
  fi

  local path="/v1/commands"
  if [ -n "$room_id" ]; then
    path="/v1/rooms/$(urlencode "$room_id")/commands"
  fi

  local corr="${CORRELATION_ID:-}"
  if [ -z "$corr" ]; then
    corr="$(generate_correlation_id)"
  fi
  CORRELATION_ID="$corr"

  http_json POST "$path" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}" \
    --header "X-Command-Id: ${command_id}" \
    --data "$body"
}

stream_sse() {
  local path="$1"
  local token="${2:-}"
  local last_event_id="${3:-}"
  local url="${BASE_URL}${path}"
  local hdr
  hdr="$(mktemp)"

  local corr="${CORRELATION_ID:-}"
  if [ -z "$corr" ]; then
    corr="$(generate_correlation_id)"
  fi

  local -a curl_args=(
    --silent --show-error --no-buffer -N
    --header "Accept: text/event-stream"
    --header "X-Correlation-Id: ${corr}"
    -D "$hdr"
  )

  if [ -n "$token" ]; then
    curl_args+=(--header "Authorization: Bearer ${token}")
  fi
  if [ -n "$last_event_id" ]; then
    curl_args+=(--header "Last-Event-ID: ${last_event_id}")
  fi

  # Stream success bodies to stdout; after the pipe, fail nonzero on HTTP 4xx/5xx.
  set +e
  curl "${curl_args[@]}" "$url" | while IFS= read -r line || [ -n "$line" ]; do
    printf '%s\n' "$line"
    case "$line" in
      data:*)
        data="${line#data:}"
        data="${data# }"
        case "$data" in
          *expiresAt*)
            case "$data" in
              *openingSequence*|*openingRoomSequence*)
                python3 - "$data" <<'PY' >&2
import json, sys
from datetime import datetime, timezone

raw = sys.argv[1]
try:
    obj = json.loads(raw)
except json.JSONDecodeError:
    sys.exit(0)

def opening_from(d):
    if not isinstance(d, dict):
        return None
    if d.get("openingSequence") is not None:
        return d.get("openingSequence")
    return d.get("openingRoomSequence")  # legacy ingest alias

window = obj.get("unoWindow") if isinstance(obj, dict) else None
if not isinstance(window, dict):
    window = obj.get("uno") if isinstance(obj, dict) else None
if not isinstance(window, dict):
    window = obj if isinstance(obj, dict) else {}

expires = window.get("expiresAt") if isinstance(window, dict) else None
if expires is None and isinstance(obj, dict):
    expires = obj.get("expiresAt")
opening = opening_from(window)
if opening is None and isinstance(obj, dict):
    opening = opening_from(obj)

if expires is None or opening is None:
    sys.exit(0)

stamp = expires
if isinstance(stamp, str) and stamp.endswith("Z"):
    stamp = stamp[:-1] + "+00:00"
try:
    dt = datetime.fromisoformat(stamp)
except ValueError:
    sys.exit(0)
if dt.tzinfo is None:
    dt = dt.replace(tzinfo=timezone.utc)
now = datetime.now(timezone.utc)
remaining = max(0, int(dt.timestamp()) - int(now.timestamp()))
print(
    f"advisory uno countdown: openingSequence={opening} expiresAt={expires} remainingSeconds={remaining} (advisory only)",
    flush=True,
)
PY
                ;;
            esac
            ;;
        esac
        ;;
    esac
  done
  local curl_rc=${PIPESTATUS[0]}
  set -e

  local status=""
  if [ -s "$hdr" ]; then
    status="$(awk 'BEGIN{s=""} /^HTTP\//{s=$2} END{print s}' "$hdr")"
  fi
  rm -f "$hdr"

  if [ -n "$status" ]; then
    if [ "$status" -lt 200 ] || [ "$status" -ge 300 ]; then
      fail "SSE ${path} returned HTTP ${status}"
    fi
  fi
  if [ "$curl_rc" -ne 0 ]; then
    fail "SSE request failed (curl exit ${curl_rc}) GET ${url}"
  fi
  if [ -z "$status" ]; then
    fail "SSE ${path} returned no HTTP status"
  fi
}

cmd_countdown() {
  local expires_at="" opening_sequence="" now_stamp="" as_json=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --expires-at)
        [ "$#" -ge 2 ] || usage
        expires_at="$2"
        shift 2
        ;;
      --opening-sequence)
        [ "$#" -ge 2 ] || usage
        opening_sequence="$2"
        shift 2
        ;;
      --now)
        [ "$#" -ge 2 ] || usage
        now_stamp="$2"
        shift 2
        ;;
      --json)
        as_json=1
        shift
        ;;
      *)
        usage
        ;;
    esac
  done

  [ -n "$expires_at" ] && [ -n "$opening_sequence" ] || usage
  require_uint "openingSequence" "$opening_sequence"
  require_command python3

  local expires_epoch now_epoch remaining expired
  expires_epoch="$(rfc3339_to_epoch "$expires_at")"
  if [ -n "$now_stamp" ]; then
    now_epoch="$(rfc3339_to_epoch "$now_stamp")"
  else
    now_epoch="$(date -u +%s)"
  fi

  remaining=$((expires_epoch - now_epoch))
  expired=0
  if [ "$remaining" -le 0 ]; then
    remaining=0
    expired=1
  fi

  if [ "$as_json" -eq 1 ]; then
    json_object \
      bool advisory true \
      number openingSequence "$opening_sequence" \
      string expiresAt "$expires_at" \
      number remainingSeconds "$remaining" \
      bool expired "$([ "$expired" -eq 1 ] && echo true || echo false)"
    printf '\n'
  else
    printf 'advisory=true openingSequence=%s expiresAt=%s remainingSeconds=%s expired=%s\n' \
      "$opening_sequence" "$expires_at" "$remaining" "$([ "$expired" -eq 1 ] && echo true || echo false)"
  fi
}

cmd_logout() {
  if [ "$#" -gt 0 ]; then
    usage
  fi
  session_remove
  printf '%s\n' '{"status":"ok"}'
}

register_already_exists() {
  # Returns 0 when register response indicates username already taken.
  local code="$1" body="$2"
  if [ "$code" = "200" ]; then
    return 1
  fi
  printf '%s' "$body" | python3 -c '
import json, sys
raw = sys.stdin.read()
text = raw.lower()
try:
    obj = json.loads(raw)
except json.JSONDecodeError:
    obj = {}
msg = str(obj.get("message", "")).lower()
code = str(obj.get("code", "")).lower()
needles = ("username taken", "already exists", "already registered", "username_taken", "conflict")
if any(n in msg or n in code or n in text for n in needles):
    sys.exit(0)
sys.exit(1)
'
}

cmd_seed() {
  local count="" prefix="$SEED_DEFAULT_PREFIX"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --count)
        [ "$#" -ge 2 ] || usage
        count="$2"
        shift 2
        ;;
      --prefix)
        [ "$#" -ge 2 ] || usage
        prefix="$2"
        shift 2
        ;;
      *)
        usage
        ;;
    esac
  done
  [ -n "$count" ] || usage
  require_positive_uint "count" "$count"
  if [ "$count" -gt "$SEED_MAX_COUNT" ]; then
    fail "count must be <= ${SEED_MAX_COUNT} (got: ${count})"
  fi
  case "$prefix" in
    ''|*[!a-zA-Z0-9_-]*)
      fail "prefix must be non-empty alphanumeric/[_-] (got: ${prefix})"
      ;;
  esac

  local i username password line_status any_fail=0
  local reg_code reg_body login_body token player_id session_id
  for ((i = 1; i <= count; i++)); do
    printf -v username '%s%04d' "$prefix" "$i"
    password="${username}-pass"

    http_exchange POST "/v1/auth/register" \
      --header "Content-Type: application/json" \
      --data "$(json_object string username "$username" string password "$password")"
    reg_code="$HTTP_CODE"
    reg_body="$HTTP_BODY"

    if [ "$reg_code" -ge 200 ] && [ "$reg_code" -lt 300 ]; then
      :
    elif register_already_exists "$reg_code" "$reg_body"; then
      :
    else
      any_fail=1
      json_object \
        string username "$username" \
        string password "$password" \
        string result "error" \
        string error "register HTTP ${reg_code}"
      continue
    fi

    http_exchange POST "/v1/auth/login" \
      --header "Content-Type: application/json" \
      --data "$(json_object string username "$username" string password "$password")"
    if [ "$HTTP_CODE" -lt 200 ] || [ "$HTTP_CODE" -ge 300 ]; then
      any_fail=1
      json_object \
        string username "$username" \
        string password "$password" \
        string result "error" \
        string error "login HTTP ${HTTP_CODE}"
      continue
    fi
    login_body="$HTTP_BODY"
    token="$(json_get "$login_body" token)"
    player_id="$(json_get "$login_body" playerId)"
    session_id="$(json_get "$login_body" sessionId)"
    if [ -z "$token" ] || [ -z "$player_id" ] || [ -z "$session_id" ]; then
      any_fail=1
      json_object \
        string username "$username" \
        string password "$password" \
        string result "error" \
        string error "login response missing token/playerId/sessionId"
      continue
    fi

    if [ "$reg_code" -ge 200 ] && [ "$reg_code" -lt 300 ]; then
      line_status="ok"
    else
      line_status="exists"
    fi
    json_object \
      string username "$username" \
      string password "$password" \
      string token "$token" \
      string playerId "$player_id" \
      string sessionId "$session_id" \
      string result "$line_status"
  done

  if [ "$any_fail" -ne 0 ]; then
    exit 1
  fi
}

cmd_room_create() {
  local max_seats=""
  local payload_set=0
  # Re-parse to capture --max while reusing common flags.
  USERNAME=""
  PASSWORD=""
  TOKEN=""
  TOKEN_FROM_FLAG=0
  ROOM_ID=""
  COMMAND_ID=""
  EXPECTED_SEQUENCE=""
  PAYLOAD="{}"
  SCHEMA_VERSION="1"
  LAST_EVENT_ID=""
  CMD_TYPE=""
  CORRELATION_ID=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --max)
        [ "$#" -ge 2 ] || usage
        max_seats="$2"
        shift 2
        ;;
      --user)
        [ "$#" -ge 2 ] || usage
        USERNAME="$2"
        shift 2
        ;;
      --pass)
        [ "$#" -ge 2 ] || usage
        PASSWORD="$2"
        shift 2
        ;;
      --token)
        [ "$#" -ge 2 ] || usage
        TOKEN="$2"
        TOKEN_FROM_FLAG=1
        shift 2
        ;;
      --room-id)
        [ "$#" -ge 2 ] || usage
        ROOM_ID="$2"
        shift 2
        ;;
      --command-id)
        [ "$#" -ge 2 ] || usage
        COMMAND_ID="$2"
        shift 2
        ;;
      --expected-sequence)
        [ "$#" -ge 2 ] || usage
        EXPECTED_SEQUENCE="$2"
        shift 2
        ;;
      --payload)
        [ "$#" -ge 2 ] || usage
        PAYLOAD="$2"
        payload_set=1
        shift 2
        ;;
      --schema-version)
        [ "$#" -ge 2 ] || usage
        SCHEMA_VERSION="$2"
        shift 2
        ;;
      --correlation-id)
        [ "$#" -ge 2 ] || usage
        CORRELATION_ID="$2"
        shift 2
        ;;
      *)
        usage
        ;;
    esac
  done

  resolve_token
  [ -n "$TOKEN" ] || usage

  if [ "$payload_set" -eq 1 ] && [ -n "$max_seats" ]; then
    fail "room create: --max and --payload are mutually exclusive"
  fi

  local room_id=""
  if [ "$payload_set" -eq 0 ]; then
    room_id="$(generate_id room)"
    if [ -n "$max_seats" ]; then
      require_uint "max" "$max_seats"
      if [ "$max_seats" -lt 2 ] || [ "$max_seats" -gt 10 ]; then
        fail "max must be between 2 and 10 (got: ${max_seats})"
      fi
      PAYLOAD="$(json_object string roomId "$room_id" number maxSeats "$max_seats")"
    else
      PAYLOAD="$(json_object string roomId "$room_id")"
    fi
  else
    room_id="$(printf '%s' "$PAYLOAD" | python3 -c '
import json, sys
try:
    obj = json.load(sys.stdin)
except json.JSONDecodeError:
    sys.exit(0)
v = obj.get("roomId") if isinstance(obj, dict) else None
print(v if isinstance(v, str) else "")
')"
  fi

  local resp status
  resp="$(submit_command_envelope "$TOKEN" "CreateRoom" "$COMMAND_ID" "$SCHEMA_VERSION" "$PAYLOAD" "" "$EXPECTED_SEQUENCE")"
  printf '%s' "$resp"
  if [ -n "$resp" ] && [ "${resp%"${resp##?}"}" != $'\n' ]; then
    printf '\n'
  fi
  status="$(json_get "$resp" status)"
  if [ "$status" = "accepted" ]; then
    if [ -z "$room_id" ]; then
      room_id="$(printf '%s' "$resp" | python3 -c '
import json, sys
try:
    obj = json.load(sys.stdin)
except json.JSONDecodeError:
    sys.exit(0)
payload = obj.get("payload") if isinstance(obj, dict) else None
if isinstance(payload, dict):
    v = payload.get("roomId")
    if isinstance(v, str):
        print(v)
')"
    fi
    if [ -n "$room_id" ] && [ -e "$(session_path)" ]; then
      session_update_room "$room_id"
    fi
  fi
}

cmd_room_list() {
  local status="" limit="" cursor=""
  CORRELATION_ID=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --status)
        [ "$#" -ge 2 ] || usage
        status="$2"
        shift 2
        ;;
      --limit)
        [ "$#" -ge 2 ] || usage
        limit="$2"
        shift 2
        ;;
      --cursor)
        [ "$#" -ge 2 ] || usage
        cursor="$2"
        shift 2
        ;;
      --correlation-id)
        [ "$#" -ge 2 ] || usage
        CORRELATION_ID="$2"
        shift 2
        ;;
      *)
        usage
        ;;
    esac
  done

  if [ -n "$status" ]; then
    case "$status" in
      waiting|locked|in_progress) ;;
      *) fail "status must be waiting|locked|in_progress (got: ${status})" ;;
    esac
  fi
  if [ -n "$limit" ]; then
    require_positive_uint "limit" "$limit"
    if [ "$limit" -gt 100 ]; then
      fail "limit must be <= 100 (got: ${limit})"
    fi
  fi

  local qs="" sep="?"
  if [ -n "$status" ]; then
    qs="${qs}${sep}status=$(urlencode "$status")"
    sep="&"
  fi
  if [ -n "$limit" ]; then
    qs="${qs}${sep}limit=$(urlencode "$limit")"
    sep="&"
  fi
  if [ -n "$cursor" ]; then
    qs="${qs}${sep}cursor=$(urlencode "$cursor")"
    sep="&"
  fi
  http_json GET "/v1/rooms${qs}"
}

cmd_room_join() {
  local room_pos=""
  if [ "$#" -gt 0 ] && [[ "$1" != --* ]]; then
    room_pos="$1"
    shift
  fi
  parse_common_flags "$@"
  resolve_token
  local room_id="${room_pos}"
  [ -n "$room_id" ] || usage
  [ -n "$TOKEN" ] || usage

  local snap seq payload resp status
  snap="$(http_json GET "/v1/spectator/rooms/$(urlencode "$room_id")/snapshot")"
  seq="$(json_get "$snap" sequence)"
  case "$seq" in
    ''|*[!0-9]*)
      fail "spectator snapshot missing authoritative sequence for room '${room_id}'"
      ;;
  esac
  payload="$(json_object string roomId "$room_id")"
  resp="$(submit_command_envelope "$TOKEN" "JoinRoom" "$COMMAND_ID" "$SCHEMA_VERSION" "$payload" "$room_id" "$seq")"
  printf '%s' "$resp"
  if [ -n "$resp" ] && [ "${resp%"${resp##?}"}" != $'\n' ]; then
    printf '\n'
  fi
  status="$(json_get "$resp" status)"
  if [ "$status" = "accepted" ] && [ -e "$(session_path)" ]; then
    session_update_room "$room_id"
  fi
}

cmd_room_leave() {
  local room_pos=""
  if [ "$#" -gt 0 ] && [[ "$1" != --* ]]; then
    room_pos="$1"
    shift
  fi
  parse_common_flags "$@"
  resolve_token
  [ -n "$TOKEN" ] || usage

  local room_id="$room_pos"
  if [ -z "$room_id" ]; then
    if [ -e "$(session_path)" ]; then
      room_id="$(session_room_or_empty || true)"
    fi
  fi
  [ -n "$room_id" ] || fail "room leave requires <roomId> or a session current room"

  local snap seq payload resp status
  snap="$(http_json GET "/v1/rooms/$(urlencode "$room_id")/snapshot" \
    --header "Authorization: Bearer ${TOKEN}")"
  seq="$(json_get "$snap" sequenceNumber)"
  case "$seq" in
    ''|*[!0-9]*)
      fail "player snapshot missing authoritative sequenceNumber for room '${room_id}'"
      ;;
  esac
  payload="$(json_object string roomId "$room_id")"
  resp="$(submit_command_envelope "$TOKEN" "LeaveRoom" "$COMMAND_ID" "$SCHEMA_VERSION" "$payload" "$room_id" "$seq")"
  printf '%s' "$resp"
  if [ -n "$resp" ] && [ "${resp%"${resp##?}"}" != $'\n' ]; then
    printf '\n'
  fi
  status="$(json_get "$resp" status)"
  if [ "$status" = "accepted" ] && [ -e "$(session_path)" ]; then
    session_clear_room
  fi
}

cmd_tournament_register() {
  local tour_pos=""
  local payload_set=0
  if [ "$#" -gt 0 ] && [[ "$1" != --* ]]; then
    tour_pos="$1"
    shift
  fi

  USERNAME=""
  PASSWORD=""
  TOKEN=""
  TOKEN_FROM_FLAG=0
  ROOM_ID=""
  COMMAND_ID=""
  EXPECTED_SEQUENCE=""
  PAYLOAD="{}"
  SCHEMA_VERSION="1"
  LAST_EVENT_ID=""
  CMD_TYPE=""
  CORRELATION_ID=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --token)
        [ "$#" -ge 2 ] || usage
        TOKEN="$2"
        TOKEN_FROM_FLAG=1
        shift 2
        ;;
      --command-id)
        [ "$#" -ge 2 ] || usage
        COMMAND_ID="$2"
        shift 2
        ;;
      --expected-sequence)
        [ "$#" -ge 2 ] || usage
        EXPECTED_SEQUENCE="$2"
        shift 2
        ;;
      --payload)
        [ "$#" -ge 2 ] || usage
        PAYLOAD="$2"
        payload_set=1
        shift 2
        ;;
      --schema-version)
        [ "$#" -ge 2 ] || usage
        SCHEMA_VERSION="$2"
        shift 2
        ;;
      --correlation-id)
        [ "$#" -ge 2 ] || usage
        CORRELATION_ID="$2"
        shift 2
        ;;
      *)
        usage
        ;;
    esac
  done

  if [ -n "$tour_pos" ] && [ "$payload_set" -eq 1 ]; then
    fail "tournament register: positional <id> and --payload are mutually exclusive"
  fi
  if [ -z "$tour_pos" ] && [ "$payload_set" -eq 0 ]; then
    usage
  fi

  resolve_token
  [ -n "$TOKEN" ] || usage

  if [ -n "$tour_pos" ]; then
    local player_id=""
    if [ -e "$(session_path)" ]; then
      player_id="$(session_player_id || true)"
    fi
    if [ -z "$player_id" ]; then
      local who
      who="$(http_json GET "/v1/auth/whoami" --header "Authorization: Bearer ${TOKEN}")"
      player_id="$(json_get "$who" playerId)"
    fi
    [ -n "$player_id" ] || fail "unable to resolve playerId for tournament register"
    PAYLOAD="$(json_object string tournamentId "$tour_pos" string playerId "$player_id")"
  fi

  submit_command_envelope "$TOKEN" "RegisterPlayer" "$COMMAND_ID" "$SCHEMA_VERSION" "$PAYLOAD" "" "$EXPECTED_SEQUENCE"
}

cmd_tournament_status() {
  local tour_id=""
  if [ "$#" -gt 0 ] && [[ "$1" != --* ]]; then
    tour_id="$1"
    shift
  fi
  parse_common_flags "$@"
  resolve_token
  [ -n "$tour_id" ] || usage

  local standings bracket
  if [ -n "$TOKEN" ]; then
    standings="$(http_json GET "/v1/tournaments/$(urlencode "$tour_id")/standings" \
      --header "Authorization: Bearer ${TOKEN}")"
    bracket="$(http_json GET "/v1/tournaments/$(urlencode "$tour_id")/bracket" \
      --header "Authorization: Bearer ${TOKEN}")"
  else
    standings="$(http_json GET "/v1/tournaments/$(urlencode "$tour_id")/standings")"
    bracket="$(http_json GET "/v1/tournaments/$(urlencode "$tour_id")/bracket")"
  fi
  python3 - "$tour_id" "$standings" "$bracket" <<'PY'
import json, sys
tid, standings_raw, bracket_raw = sys.argv[1:4]
standings = json.loads(standings_raw)
bracket = json.loads(bracket_raw)
print(json.dumps({
    "tournamentId": tid,
    "standings": standings,
    "bracket": bracket,
}, separators=(",", ":")))
PY
  printf '\n'
}

parse_common_flags() {
  # Sets globals: USERNAME PASSWORD TOKEN ROOM_ID COMMAND_ID EXPECTED_SEQUENCE
  # PAYLOAD SCHEMA_VERSION LAST_EVENT_ID CMD_TYPE CORRELATION_ID TOKEN_FROM_FLAG
  # HTTP responses are always JSON; --json is not accepted here (countdown only).
  USERNAME=""
  PASSWORD=""
  TOKEN=""
  TOKEN_FROM_FLAG=0
  ROOM_ID=""
  COMMAND_ID=""
  EXPECTED_SEQUENCE=""
  PAYLOAD="{}"
  SCHEMA_VERSION="1"
  LAST_EVENT_ID=""
  CMD_TYPE=""
  CORRELATION_ID=""
  MAX_SEATS=""
  STATUS_FILTER=""
  LIMIT=""
  CURSOR=""
  COUNT=""
  PREFIX=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --user)
        [ "$#" -ge 2 ] || usage
        USERNAME="$2"
        shift 2
        ;;
      --pass)
        [ "$#" -ge 2 ] || usage
        PASSWORD="$2"
        shift 2
        ;;
      --token)
        [ "$#" -ge 2 ] || usage
        TOKEN="$2"
        TOKEN_FROM_FLAG=1
        shift 2
        ;;
      --room-id)
        [ "$#" -ge 2 ] || usage
        ROOM_ID="$2"
        shift 2
        ;;
      --command-id)
        [ "$#" -ge 2 ] || usage
        COMMAND_ID="$2"
        shift 2
        ;;
      --expected-sequence)
        [ "$#" -ge 2 ] || usage
        EXPECTED_SEQUENCE="$2"
        shift 2
        ;;
      --payload)
        [ "$#" -ge 2 ] || usage
        PAYLOAD="$2"
        shift 2
        ;;
      --schema-version)
        [ "$#" -ge 2 ] || usage
        SCHEMA_VERSION="$2"
        shift 2
        ;;
      --last-event-id)
        [ "$#" -ge 2 ] || usage
        LAST_EVENT_ID="$2"
        shift 2
        ;;
      --correlation-id)
        [ "$#" -ge 2 ] || usage
        CORRELATION_ID="$2"
        shift 2
        ;;
      --type)
        [ "$#" -ge 2 ] || usage
        CMD_TYPE="$2"
        shift 2
        ;;
      --max)
        [ "$#" -ge 2 ] || usage
        MAX_SEATS="$2"
        shift 2
        ;;
      --status)
        [ "$#" -ge 2 ] || usage
        STATUS_FILTER="$2"
        shift 2
        ;;
      --limit)
        [ "$#" -ge 2 ] || usage
        LIMIT="$2"
        shift 2
        ;;
      --cursor)
        [ "$#" -ge 2 ] || usage
        CURSOR="$2"
        shift 2
        ;;
      --count)
        [ "$#" -ge 2 ] || usage
        COUNT="$2"
        shift 2
        ;;
      --prefix)
        [ "$#" -ge 2 ] || usage
        PREFIX="$2"
        shift 2
        ;;
      *)
        usage
        ;;
    esac
  done
}

require_command curl
require_command python3

command_name="${1:-}"
if [ -z "$command_name" ]; then
  usage
fi
shift

# Stage B lives in a stdlib Python runtime while preserving this Bash executable
# as the sole stable entrypoint and keeping all traffic at the Gateway/BFF edge.
case "$command_name" in
  play|bot)
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    exec python3 "${SCRIPT_DIR}/../lib/game_client.py" "$command_name" "$@"
    ;;
esac

# Nested tournament / stream / room verbs.
subcommand=""
case "$command_name" in
  tournament|stream|room)
    subcommand="${1:-}"
    [ -n "$subcommand" ] || usage
    shift
    ;;
esac

# Local-only commands (no gateway URL).
case "$command_name" in
  countdown)
    cmd_countdown "$@"
    exit 0
    ;;
  logout)
    cmd_logout "$@"
    exit 0
    ;;
esac

API_URL="${UNOARENA_API_URL:?UNOARENA_API_URL must be set}"
BASE_URL="${API_URL%/}"

case "$command_name" in
  health)
    parse_common_flags "$@"
    http_json GET "/health"
    ;;
  register)
    parse_common_flags "$@"
    [ -n "$USERNAME" ] && [ -n "$PASSWORD" ] || usage
    http_json POST "/v1/auth/register" \
      --header "Content-Type: application/json" \
      --data "$(json_object string username "$USERNAME" string password "$PASSWORD")"
    ;;
  login)
    parse_common_flags "$@"
    [ -n "$USERNAME" ] && [ -n "$PASSWORD" ] || usage
    login_body="$(http_json POST "/v1/auth/login" \
      --header "Content-Type: application/json" \
      --data "$(json_object string username "$USERNAME" string password "$PASSWORD")")"
    printf '%s' "$login_body"
    if [ -n "$login_body" ] && [ "${login_body%"${login_body##?}"}" != $'\n' ]; then
      printf '\n'
    fi
    login_token="$(json_get "$login_body" token)"
    login_player="$(json_get "$login_body" playerId)"
    login_session="$(json_get "$login_body" sessionId)"
    if [ -n "$login_token" ] && [ -n "$login_player" ] && [ -n "$login_session" ]; then
      session_write "$login_token" "$login_player" "$login_session" "$USERNAME" ""
    fi
    ;;
  whoami)
    parse_common_flags "$@"
    resolve_token
    [ -n "$TOKEN" ] || usage
    http_json GET "/v1/auth/whoami" \
      --header "Authorization: Bearer ${TOKEN}"
    ;;
  seed)
    cmd_seed "$@"
    ;;
  room)
    case "$subcommand" in
      create)
        cmd_room_create "$@"
        ;;
      list)
        cmd_room_list "$@"
        ;;
      join)
        cmd_room_join "$@"
        ;;
      leave)
        cmd_room_leave "$@"
        ;;
      *)
        usage
        ;;
    esac
    ;;
  command)
    parse_common_flags "$@"
    resolve_token
    [ -n "$TOKEN" ] && [ -n "$CMD_TYPE" ] || usage
    submit_command_envelope "$TOKEN" "$CMD_TYPE" "$COMMAND_ID" "$SCHEMA_VERSION" "$PAYLOAD" "$ROOM_ID" "$EXPECTED_SEQUENCE"
    ;;
  tournament)
    case "$subcommand" in
      create)
        parse_common_flags "$@"
        resolve_token
        [ -n "$TOKEN" ] || usage
        submit_command_envelope "$TOKEN" "CreateTournament" "$COMMAND_ID" "$SCHEMA_VERSION" "$PAYLOAD" "" "$EXPECTED_SEQUENCE"
        ;;
      register)
        cmd_tournament_register "$@"
        ;;
      close-registration)
        parse_common_flags "$@"
        resolve_token
        [ -n "$TOKEN" ] || usage
        submit_command_envelope "$TOKEN" "CloseRegistration" "$COMMAND_ID" "$SCHEMA_VERSION" "$PAYLOAD" "" "$EXPECTED_SEQUENCE"
        ;;
      status)
        cmd_tournament_status "$@"
        ;;
      *)
        usage
        ;;
    esac
    ;;
  spectate)
    room_pos=""
    if [ "$#" -gt 0 ] && [[ "$1" != --* ]]; then
      room_pos="$1"
      shift
    fi
    parse_common_flags "$@"
    resolve_token
    [ -n "$room_pos" ] || usage
    stream_sse "/v1/streams/spectator?roomId=$(urlencode "$room_pos")" \
      "$TOKEN" "$LAST_EVENT_ID"
    ;;
  stream)
    parse_common_flags "$@"
    resolve_token
    case "$subcommand" in
      player)
        [ -n "$ROOM_ID" ] || usage
        [ -n "$TOKEN" ] || usage
        stream_sse "/v1/streams/player?roomId=$(urlencode "$ROOM_ID")" \
          "$TOKEN" "$LAST_EVENT_ID"
        ;;
      spectator)
        [ -n "$ROOM_ID" ] || usage
        stream_sse "/v1/streams/spectator?roomId=$(urlencode "$ROOM_ID")" \
          "$TOKEN" "$LAST_EVENT_ID"
        ;;
      control)
        [ -n "$TOKEN" ] || usage
        stream_sse "/v1/streams/control" "$TOKEN" "$LAST_EVENT_ID"
        ;;
      *)
        usage
        ;;
    esac
    ;;
  leaderboard)
    parse_common_flags "$@"
    http_json GET "/v1/rankings/leaderboards"
    ;;
  analytics)
    parse_common_flags "$@"
    http_json GET "/v1/analytics/public"
    ;;
  *)
    usage
    ;;
esac
