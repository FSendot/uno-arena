#!/usr/bin/env bash
# UnoArena Client Checkpoint CLI — sole client/test interface for this implementation.
# Speaks only to the Realtime Gateway / BFF via UNOARENA_API_URL. No direct service calls.
set -euo pipefail

usage() {
  cat >&2 <<'USAGE'
Usage:
  unoarena health
  unoarena register --user <username> --pass <password>
  unoarena login --user <username> --pass <password>
  unoarena whoami --token <bearer-token>
  unoarena room create --token <bearer-token> [--command-id <id>] [--payload <json>]
  unoarena command --token <bearer-token> --type <CommandType>
                   [--room-id <roomId>] [--command-id <id>]
                   --expected-sequence <n>   # required for existing room mutations
                   [--payload <json>] [--schema-version <n>]
  unoarena tournament create --token <bearer-token> [--command-id <id>] [--payload <json>]
  unoarena tournament register --token <bearer-token> [--command-id <id>] [--payload <json>]
  unoarena tournament close-registration --token <bearer-token>
                   [--command-id <id>] [--payload <json>]
  unoarena stream player --token <bearer-token> --room-id <roomId> [--last-event-id <id>]
  unoarena stream spectator --room-id <roomId> [--token <bearer-token>] [--last-event-id <id>]
  unoarena stream control --token <bearer-token> [--last-event-id <id>]
  unoarena leaderboard
  unoarena analytics
  unoarena countdown --expires-at <RFC3339> --opening-sequence <n>
                   [--now <RFC3339>] [--json]

Environment:
  UNOARENA_API_URL   Gateway/BFF base URL (required except for countdown)
  UNOARENA_TOKEN     Optional default bearer token when --token is omitted

Notes:
  - All HTTP calls target UNOARENA_API_URL only (OpenAPI BFF paths).
  - HTTP responses are always JSON; --json is only meaningful for countdown
    (structured JSON vs text line).
  - schemaVersion must equal 1.
  - expectedSequenceNumber is required for mutations of an existing room aggregate.
    Documented exception: CreateRoom (no room aggregate yet). Tournament commands
    do not use room sequence.
  - Countdown is advisory; server expiresAt + openingSequence remain authoritative.
    SSE advisory accepts canonical openingSequence and legacy openingRoomSequence.
  - Graphical UI is deferred; this CLI is the sole current client interface.
USAGE
  exit 2
}

fail() {
  echo "FAIL: $*" >&2
  exit 1
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    fail "required command '$1' is not available"
  fi
}

# Strict non-negative integer (digits only). Rejects signs, decimals, whitespace.
require_uint() {
  local label="$1" value="$2"
  case "$value" in
    ''|*[!0-9]*)
      fail "${label} must be a non-negative integer (got: ${value})"
      ;;
  esac
}

# schemaVersion must equal 1 (current BFF contract).
require_schema_version() {
  local value="$1"
  require_uint "schemaVersion" "$value"
  if [ "$value" -ne 1 ]; then
    fail "schemaVersion must be 1 (got: ${value})"
  fi
}

urlencode() {
  local value="$1"
  local encoded=""
  local i char

  LC_ALL=C
  for ((i = 0; i < ${#value}; i++)); do
    char="${value:i:1}"
    case "$char" in
      [a-zA-Z0-9.~_-]) encoded+="$char" ;;
      *) printf -v encoded '%s%%%02X' "$encoded" "'$char" ;;
    esac
  done

  printf '%s' "$encoded"
}

generate_id() {
  local prefix="${1:-id}"
  if command -v uuidgen >/dev/null 2>&1; then
    printf '%s' "$(uuidgen | tr '[:upper:]' '[:lower:]')"
    return
  fi
  if [ -r /proc/sys/kernel/random/uuid ]; then
    tr -d '\n' </proc/sys/kernel/random/uuid
    return
  fi
  printf '%s-%s-%s' "$prefix" "$$" "$(date -u +%Y%m%d%H%M%S)"
}

generate_command_id() {
  generate_id "cmd"
}

generate_correlation_id() {
  generate_id "corr"
}

# Build JSON object via python stdlib (safe encoding).
# Args are triplets: KIND KEY VALUE
#   string — always a JSON string (untrusted scalars: username, password, ids, types)
#   number — already-validated non-negative integer
#   bool   — already-validated true/false
#   json   — already-validated JSON value (e.g. payload object)
# No in-band value sentinel: a string beginning with "raw:" stays a string.
json_object() {
  require_command python3
  python3 - "$@" <<'PY'
import json, sys

args = sys.argv[1:]
if len(args) % 3 != 0:
    print("FAIL: json_object requires kind/key/value triplets", file=sys.stderr)
    sys.exit(1)

out = {}
i = 0
while i < len(args):
    kind = args[i]
    key = args[i + 1]
    val = args[i + 2]
    i += 3
    if kind == "string":
        out[key] = val
    elif kind == "number":
        if not val.isdigit():
            print(f"FAIL: number field {key} must be a non-negative integer (got: {val})", file=sys.stderr)
            sys.exit(1)
        out[key] = int(val)
    elif kind == "bool":
        if val == "true":
            out[key] = True
        elif val == "false":
            out[key] = False
        else:
            print(f"FAIL: bool field {key} must be true or false (got: {val})", file=sys.stderr)
            sys.exit(1)
    elif kind == "json":
        try:
            out[key] = json.loads(val)
        except json.JSONDecodeError as exc:
            print(f"FAIL: invalid JSON for {key}: {exc}", file=sys.stderr)
            sys.exit(1)
    else:
        print(f"FAIL: unknown json_object kind '{kind}' (use string|number|bool|json)", file=sys.stderr)
        sys.exit(1)

print(json.dumps(out, separators=(",", ":")))
PY
}

# Validate payload is a JSON object; reprint canonical form.
canonicalize_payload_object() {
  local payload="$1"
  require_command python3
  python3 - "$payload" <<'PY'
import json, sys

raw = sys.argv[1]
try:
    obj = json.loads(raw)
except json.JSONDecodeError as exc:
    print(f"FAIL: payload must be valid JSON: {exc}", file=sys.stderr)
    sys.exit(1)
if not isinstance(obj, dict):
    print("FAIL: payload must be a JSON object", file=sys.stderr)
    sys.exit(1)
print(json.dumps(obj, separators=(",", ":")))
PY
}

# Portable RFC3339 -> epoch seconds (UTC). Uses python3 stdlib only.
rfc3339_to_epoch() {
  local stamp="$1"
  python3 - "$stamp" <<'PY'
import sys
from datetime import datetime, timezone

raw = sys.argv[1]
if raw.endswith("Z"):
    raw = raw[:-1] + "+00:00"
dt = datetime.fromisoformat(raw)
if dt.tzinfo is None:
    dt = dt.replace(tzinfo=timezone.utc)
print(int(dt.timestamp()))
PY
}

# Documented exception: CreateRoom. Tournament commands are not room mutations.
requires_expected_sequence() {
  local cmd_type="$1"
  case "$cmd_type" in
    CreateRoom|CreateTournament|RegisterPlayer|CloseRegistration)
      return 1
      ;;
    JoinRoom|LeaveRoom|LockRoom|StartMatch|CancelRoom|PlayCard|DrawCard|ChooseColor|CallUno|ReportMissingUno|ReconnectToRoom)
      return 0
      ;;
    *)
      # Unknown types: only room-scoped paths force sequence (checked by caller).
      return 1
      ;;
  esac
}

http_json() {
  # http_json METHOD PATH [curl args...]
  # Prints response body on stdout. Exits 1 on transport/HTTP error with clear stderr.
  local method="$1"
  local path="$2"
  shift 2
  local url="${BASE_URL}${path}"
  local tmp_body tmp_code code body curl_rc
  tmp_body="$(mktemp)"
  tmp_code="$(mktemp)"

  local corr="${CORRELATION_ID:-}"
  if [ -z "$corr" ]; then
    corr="$(generate_correlation_id)"
  fi

  set +e
  curl --silent --show-error \
    --request "$method" \
    --output "$tmp_body" \
    --write-out '%{http_code}' \
    --header "X-Correlation-Id: ${corr}" \
    "$@" \
    "$url" >"$tmp_code"
  curl_rc=$?
  set -e

  code="$(tr -d '\n' <"$tmp_code")"
  body="$(cat "$tmp_body")"
  rm -f "$tmp_body" "$tmp_code"

  if [ "$curl_rc" -ne 0 ]; then
    fail "HTTP request failed (curl exit ${curl_rc}) ${method} ${url}"
  fi

  if [ "$code" -lt 200 ] || [ "$code" -ge 300 ]; then
    echo "FAIL: ${method} ${path} returned HTTP ${code}" >&2
    if [ -n "$body" ]; then
      echo "$body" >&2
    fi
    exit 1
  fi

  printf '%s' "$body"
  if [ -n "$body" ] && [ "${body%"${body##?}"}" != $'\n' ]; then
    printf '\n'
  fi
}

submit_command_envelope() {
  local token="$1"
  local cmd_type="$2"
  local command_id="$3"
  local schema_version="$4"
  local payload_json="$5"
  local room_id="${6:-}"
  local expected_sequence="${7:-}"

  [ -n "$token" ] || usage
  [ -n "$cmd_type" ] || usage
  [ -n "$command_id" ] || command_id="$(generate_command_id)"
  [ -n "$schema_version" ] || schema_version="1"
  [ -n "$payload_json" ] || payload_json="{}"

  require_schema_version "$schema_version"
  payload_json="$(canonicalize_payload_object "$payload_json")"

  if requires_expected_sequence "$cmd_type"; then
    if [ -z "$expected_sequence" ]; then
      fail "expectedSequenceNumber is required for room mutation '${cmd_type}' (CreateRoom is the documented exception)"
    fi
    require_uint "expectedSequenceNumber" "$expected_sequence"
  elif [ -n "$expected_sequence" ]; then
    require_uint "expectedSequenceNumber" "$expected_sequence"
  fi

  # Room-scoped path without CreateRoom also requires sequence even for unknown types.
  if [ -n "$room_id" ] && [ "$cmd_type" != "CreateRoom" ]; then
    if [ -z "$expected_sequence" ]; then
      fail "expectedSequenceNumber is required for room-scoped command '${cmd_type}'"
    fi
    require_uint "expectedSequenceNumber" "$expected_sequence"
  fi

  local body
  if [ -n "$expected_sequence" ]; then
    body="$(json_object \
      string commandId "$command_id" \
      string type "$cmd_type" \
      number schemaVersion "$schema_version" \
      number expectedSequenceNumber "$expected_sequence" \
      json payload "$payload_json")"
  else
    body="$(json_object \
      string commandId "$command_id" \
      string type "$cmd_type" \
      number schemaVersion "$schema_version" \
      json payload "$payload_json")"
  fi

  local path="/v1/commands"
  if [ -n "$room_id" ]; then
    path="/v1/rooms/$(urlencode "$room_id")/commands"
  fi

  local corr="${CORRELATION_ID:-}"
  if [ -z "$corr" ]; then
    corr="$(generate_correlation_id)"
  fi
  CORRELATION_ID="$corr"

  http_json POST "$path" \
    --header "Content-Type: application/json" \
    --header "Authorization: Bearer ${token}" \
    --header "X-Command-Id: ${command_id}" \
    --data "$body"
}

stream_sse() {
  local path="$1"
  local token="${2:-}"
  local last_event_id="${3:-}"
  local url="${BASE_URL}${path}"
  local hdr
  hdr="$(mktemp)"

  local corr="${CORRELATION_ID:-}"
  if [ -z "$corr" ]; then
    corr="$(generate_correlation_id)"
  fi

  local -a curl_args=(
    --silent --show-error --no-buffer -N
    --header "Accept: text/event-stream"
    --header "X-Correlation-Id: ${corr}"
    -D "$hdr"
  )

  if [ -n "$token" ]; then
    curl_args+=(--header "Authorization: Bearer ${token}")
  fi
  if [ -n "$last_event_id" ]; then
    curl_args+=(--header "Last-Event-ID: ${last_event_id}")
  fi

  # Stream success bodies to stdout; after the pipe, fail nonzero on HTTP 4xx/5xx.
  set +e
  curl "${curl_args[@]}" "$url" | while IFS= read -r line || [ -n "$line" ]; do
    printf '%s\n' "$line"
    case "$line" in
      data:*)
        data="${line#data:}"
        data="${data# }"
        case "$data" in
          *expiresAt*)
            case "$data" in
              *openingSequence*|*openingRoomSequence*)
                python3 - "$data" <<'PY' >&2
import json, sys
from datetime import datetime, timezone

raw = sys.argv[1]
try:
    obj = json.loads(raw)
except json.JSONDecodeError:
    sys.exit(0)

def opening_from(d):
    if not isinstance(d, dict):
        return None
    if d.get("openingSequence") is not None:
        return d.get("openingSequence")
    return d.get("openingRoomSequence")  # legacy ingest alias

window = obj.get("unoWindow") if isinstance(obj, dict) else None
if not isinstance(window, dict):
    window = obj.get("uno") if isinstance(obj, dict) else None
if not isinstance(window, dict):
    window = obj if isinstance(obj, dict) else {}

expires = window.get("expiresAt") if isinstance(window, dict) else None
if expires is None and isinstance(obj, dict):
    expires = obj.get("expiresAt")
opening = opening_from(window)
if opening is None and isinstance(obj, dict):
    opening = opening_from(obj)

if expires is None or opening is None:
    sys.exit(0)

stamp = expires
if isinstance(stamp, str) and stamp.endswith("Z"):
    stamp = stamp[:-1] + "+00:00"
try:
    dt = datetime.fromisoformat(stamp)
except ValueError:
    sys.exit(0)
if dt.tzinfo is None:
    dt = dt.replace(tzinfo=timezone.utc)
now = datetime.now(timezone.utc)
remaining = max(0, int(dt.timestamp()) - int(now.timestamp()))
print(
    f"advisory uno countdown: openingSequence={opening} expiresAt={expires} remainingSeconds={remaining} (advisory only)",
    flush=True,
)
PY
                ;;
            esac
            ;;
        esac
        ;;
    esac
  done
  local curl_rc=${PIPESTATUS[0]}
  set -e

  local status=""
  if [ -s "$hdr" ]; then
    status="$(awk 'BEGIN{s=""} /^HTTP\//{s=$2} END{print s}' "$hdr")"
  fi
  rm -f "$hdr"

  if [ -n "$status" ]; then
    if [ "$status" -lt 200 ] || [ "$status" -ge 300 ]; then
      fail "SSE ${path} returned HTTP ${status}"
    fi
  fi
  if [ "$curl_rc" -ne 0 ]; then
    fail "SSE request failed (curl exit ${curl_rc}) GET ${url}"
  fi
  if [ -z "$status" ]; then
    fail "SSE ${path} returned no HTTP status"
  fi
}

cmd_countdown() {
  local expires_at="" opening_sequence="" now_stamp="" as_json=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --expires-at)
        [ "$#" -ge 2 ] || usage
        expires_at="$2"
        shift 2
        ;;
      --opening-sequence)
        [ "$#" -ge 2 ] || usage
        opening_sequence="$2"
        shift 2
        ;;
      --now)
        [ "$#" -ge 2 ] || usage
        now_stamp="$2"
        shift 2
        ;;
      --json)
        as_json=1
        shift
        ;;
      *)
        usage
        ;;
    esac
  done

  [ -n "$expires_at" ] && [ -n "$opening_sequence" ] || usage
  require_uint "openingSequence" "$opening_sequence"
  require_command python3

  local expires_epoch now_epoch remaining expired
  expires_epoch="$(rfc3339_to_epoch "$expires_at")"
  if [ -n "$now_stamp" ]; then
    now_epoch="$(rfc3339_to_epoch "$now_stamp")"
  else
    now_epoch="$(date -u +%s)"
  fi

  remaining=$((expires_epoch - now_epoch))
  expired=0
  if [ "$remaining" -le 0 ]; then
    remaining=0
    expired=1
  fi

  if [ "$as_json" -eq 1 ]; then
    json_object \
      bool advisory true \
      number openingSequence "$opening_sequence" \
      string expiresAt "$expires_at" \
      number remainingSeconds "$remaining" \
      bool expired "$([ "$expired" -eq 1 ] && echo true || echo false)"
    printf '\n'
  else
    printf 'advisory=true openingSequence=%s expiresAt=%s remainingSeconds=%s expired=%s\n' \
      "$opening_sequence" "$expires_at" "$remaining" "$([ "$expired" -eq 1 ] && echo true || echo false)"
  fi
}

parse_common_flags() {
  # Sets globals: USERNAME PASSWORD TOKEN ROOM_ID COMMAND_ID EXPECTED_SEQUENCE
  # PAYLOAD SCHEMA_VERSION LAST_EVENT_ID CMD_TYPE CORRELATION_ID
  # HTTP responses are always JSON; --json is not accepted here (countdown only).
  USERNAME=""
  PASSWORD=""
  TOKEN="${UNOARENA_TOKEN:-}"
  ROOM_ID=""
  COMMAND_ID=""
  EXPECTED_SEQUENCE=""
  PAYLOAD="{}"
  SCHEMA_VERSION="1"
  LAST_EVENT_ID=""
  CMD_TYPE=""
  CORRELATION_ID=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --user)
        [ "$#" -ge 2 ] || usage
        USERNAME="$2"
        shift 2
        ;;
      --pass)
        [ "$#" -ge 2 ] || usage
        PASSWORD="$2"
        shift 2
        ;;
      --token)
        [ "$#" -ge 2 ] || usage
        TOKEN="$2"
        shift 2
        ;;
      --room-id)
        [ "$#" -ge 2 ] || usage
        ROOM_ID="$2"
        shift 2
        ;;
      --command-id)
        [ "$#" -ge 2 ] || usage
        COMMAND_ID="$2"
        shift 2
        ;;
      --expected-sequence)
        [ "$#" -ge 2 ] || usage
        EXPECTED_SEQUENCE="$2"
        shift 2
        ;;
      --payload)
        [ "$#" -ge 2 ] || usage
        PAYLOAD="$2"
        shift 2
        ;;
      --schema-version)
        [ "$#" -ge 2 ] || usage
        SCHEMA_VERSION="$2"
        shift 2
        ;;
      --last-event-id)
        [ "$#" -ge 2 ] || usage
        LAST_EVENT_ID="$2"
        shift 2
        ;;
      --correlation-id)
        [ "$#" -ge 2 ] || usage
        CORRELATION_ID="$2"
        shift 2
        ;;
      --type)
        [ "$#" -ge 2 ] || usage
        CMD_TYPE="$2"
        shift 2
        ;;
      *)
        usage
        ;;
    esac
  done
}

require_command curl
require_command python3

command_name="${1:-}"
if [ -z "$command_name" ]; then
  usage
fi
shift

# Nested tournament / stream / room verbs.
subcommand=""
case "$command_name" in
  tournament|stream|room)
    subcommand="${1:-}"
    [ -n "$subcommand" ] || usage
    shift
    ;;
esac

# Countdown is local-only and does not require the gateway URL.
if [ "$command_name" = "countdown" ]; then
  cmd_countdown "$@"
  exit 0
fi

API_URL="${UNOARENA_API_URL:?UNOARENA_API_URL must be set}"
BASE_URL="${API_URL%/}"

case "$command_name" in
  health)
    parse_common_flags "$@"
    http_json GET "/health"
    ;;
  register)
    parse_common_flags "$@"
    [ -n "$USERNAME" ] && [ -n "$PASSWORD" ] || usage
    http_json POST "/v1/auth/register" \
      --header "Content-Type: application/json" \
      --data "$(json_object string username "$USERNAME" string password "$PASSWORD")"
    ;;
  login)
    parse_common_flags "$@"
    [ -n "$USERNAME" ] && [ -n "$PASSWORD" ] || usage
    http_json POST "/v1/auth/login" \
      --header "Content-Type: application/json" \
      --data "$(json_object string username "$USERNAME" string password "$PASSWORD")"
    ;;
  whoami)
    parse_common_flags "$@"
    [ -n "$TOKEN" ] || usage
    http_json GET "/v1/auth/whoami" \
      --header "Authorization: Bearer ${TOKEN}"
    ;;
  room)
    case "$subcommand" in
      create)
        parse_common_flags "$@"
        [ -n "$TOKEN" ] || usage
        submit_command_envelope "$TOKEN" "CreateRoom" "$COMMAND_ID" "$SCHEMA_VERSION" "$PAYLOAD" "" ""
        ;;
      *)
        usage
        ;;
    esac
    ;;
  command)
    parse_common_flags "$@"
    [ -n "$TOKEN" ] && [ -n "$CMD_TYPE" ] || usage
    submit_command_envelope "$TOKEN" "$CMD_TYPE" "$COMMAND_ID" "$SCHEMA_VERSION" "$PAYLOAD" "$ROOM_ID" "$EXPECTED_SEQUENCE"
    ;;
  tournament)
    parse_common_flags "$@"
    [ -n "$TOKEN" ] || usage
    case "$subcommand" in
      create)
        submit_command_envelope "$TOKEN" "CreateTournament" "$COMMAND_ID" "$SCHEMA_VERSION" "$PAYLOAD" "" ""
        ;;
      register)
        submit_command_envelope "$TOKEN" "RegisterPlayer" "$COMMAND_ID" "$SCHEMA_VERSION" "$PAYLOAD" "" ""
        ;;
      close-registration)
        submit_command_envelope "$TOKEN" "CloseRegistration" "$COMMAND_ID" "$SCHEMA_VERSION" "$PAYLOAD" "" ""
        ;;
      *)
        usage
        ;;
    esac
    ;;
  stream)
    parse_common_flags "$@"
    case "$subcommand" in
      player)
        [ -n "$ROOM_ID" ] || usage
        [ -n "$TOKEN" ] || usage
        stream_sse "/v1/streams/player?roomId=$(urlencode "$ROOM_ID")" \
          "$TOKEN" "$LAST_EVENT_ID"
        ;;
      spectator)
        [ -n "$ROOM_ID" ] || usage
        stream_sse "/v1/streams/spectator?roomId=$(urlencode "$ROOM_ID")" \
          "$TOKEN" "$LAST_EVENT_ID"
        ;;
      control)
        [ -n "$TOKEN" ] || usage
        stream_sse "/v1/streams/control" "$TOKEN" "$LAST_EVENT_ID"
        ;;
      *)
        usage
        ;;
    esac
    ;;
  leaderboard)
    parse_common_flags "$@"
    http_json GET "/v1/rankings/leaderboards"
    ;;
  analytics)
    parse_common_flags "$@"
    http_json GET "/v1/analytics/public"
    ;;
  *)
    usage
    ;;
esac
